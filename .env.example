# ═══════════════════════════════════════════════════════════
# 听一听 · 网易云 API 配置
# ═══════════════════════════════════════════════════════════

# ── 默认：NetStart 公共网易云 API（apic 备用域；主域 apis 挂了会自动切换）──
VITE_NETEASE_API_BASE=https://apic.netstart.cn/music
VITE_NETEASE_API_MODE=ncm

# ── 本机调试：npm run ncm:local ──
# VITE_NETEASE_API_BASE=http://127.0.0.1:3000
# VITE_NETEASE_API_MODE=ncm

# ── 手机真机 + 同一 WiFi（把 IP 换成 ipconfig 里的 IPv4）──
# VITE_NETEASE_API_BASE=http://192.168.1.8:3000
# VITE_NETEASE_API_MODE=ncm

# ── 自建国内 API（长期上线更稳）──
# VITE_NETEASE_API_BASE=https://你的国内API域名
# VITE_NETEASE_API_MODE=ncm

# ── 旧方案：Cloudflare Worker（国内常需梯子，不推荐）──
# VITE_NETEASE_API_BASE=https://netease-qr-login.lyx815934990.workers.dev
# VITE_NETEASE_API_MODE=worker

# ── 听一听开发占位：默认暂不可用；设为 false 时加载完整听一听模块 ──
# VITE_LISTEN_TOGETHER_UNDER_DEV=false

# ═══════════════════════════════════════════════════════════
# 后台系统通知 · 云端 Web Push 离线兜底（无需自购服务器）
# 切后台靠保活 + 本地通知；划掉/被杀后走 Worker 推送（国内常需梯子）
# ═══════════════════════════════════════════════════════════
# VITE_WEB_PUSH_API_BASE=https://lumi-push.lyx815934990.workers.dev
