# ═══════════════════════════════════════════════════════════
# 听一听 · 网易云 API 配置
# ═══════════════════════════════════════════════════════════

# ── 默认：NetStart 公共网易云 API（apic 备用域；主域 apis 挂了会自动切换）──
VITE_NETEASE_API_BASE=https://apic.netstart.cn/music
VITE_NETEASE_API_MODE=ncm

# ── 本机调试：npm run ncm:local ──
# VITE_NETEASE_API_BASE=http://127.0.0.1:3000
# VITE_NETEASE_API_MODE=ncm

# ── 手机真机 + 同一 WiFi（把 IP 换成 ipconfig 里的 IPv4）──
# VITE_NETEASE_API_BASE=http://192.168.1.8:3000
# VITE_NETEASE_API_MODE=ncm

# ── iOS Safari 局域网打不开 dev 时：关闭自签 HTTPS，改 http://本机IP:5173 ──
# VITE_DEV_HTTPS=false

# ── 自建国内 API（长期上线更稳）──
# VITE_NETEASE_API_BASE=https://你的国内API域名
# VITE_NETEASE_API_MODE=ncm

# ── 旧方案：Cloudflare Worker（国内常需梯子，不推荐）──
# VITE_NETEASE_API_BASE=https://netease-qr-login.lyx815934990.workers.dev
# VITE_NETEASE_API_MODE=worker
# ═══════════════════════════════════════════════════════════
# 后台系统通知 · 云端 Web Push 离线兜底（无需自购服务器）
# 切后台靠保活 + 本地通知；划掉/被杀后走 Worker 推送（国内常需梯子）
# ═══════════════════════════════════════════════════════════
# VITE_WEB_PUSH_API_BASE=https://lumi-push.lyx815934990.workers.dev
# 网页链接识别 · 极数本源
# GitHub Pages / 国内部署：不要填下面两项，浏览器直连 v1.apizero.cn（无需梯子）
# 仅当直连 CORS 失败时，再部署 workers/link-preview 并填写 Worker 代理（workers.dev 国内常需梯子）
# VITE_APIZERO_PROXY_BASE=https://link-preview.<子域>.workers.dev/apizero-proxy

# ═══════════════════════════════════════════════════════════
# 账号系统 · Cloudflare Worker API（登录/注册/账号中心）
# ═══════════════════════════════════════════════════════════
VITE_USER_SYSTEM_API_BASE=https://user-system-api.lyx815934990.workers.dev

# Discord OAuth（与账密登录并存；未配置则隐藏 Discord 按钮）
# 在 Discord Developer Portal → OAuth2 → Redirects 添加：
#   本地 dev：http(s)://localhost:5173/
#   GitHub Pages：https://lyx815934990-oss.github.io/Lumi-Phone/
# VITE_DISCORD_CLIENT_ID=你的Discord应用ClientID
# Worker 端还需配置 DISCORD_CLIENT_ID / DISCORD_CLIENT_SECRET，见 workers/user-system-api/README.md

# 本地 npm run dev 专用：跳过账号登录/状态/更正弹窗（仅 DEV 生效，生产构建无效）
# 已在 .env.development 默认开启；若要本地测试账号流程，在 .env.local 写：
# VITE_LOCAL_DEV_BYPASS_AUTH=false
